{
  "arazzo": "1.0.0",
  "info": {
    "title": "GitHub + OpenAI Workflows",
    "version": "0.1.0",
    "description": "Workflows combining GitHub API with OpenAI for repository analysis"
  },
  "sourceDescriptions": [
    {
      "name": "github",
      "type": "openapi",
      "url": "/app/src/specs/github.json"
    },
    {
      "name": "openai",
      "type": "openapi",
      "url": "/app/src/specs/openai.json"
    }
  ],
  "workflows": [
    {
      "workflowId": "summarise-repos",
      "summary": "List GitHub repos for a user and generate summary with OpenAI",
      "description": "Fetches all public repos for a GitHub user, then uses GPT to summarize the user's technical focus, popular projects, and language preferences.",
      "inputs": {
        "type": "object",
        "properties": {
          "github_username": {"type": "string", "description": "GitHub username to analyze"},
          "openai_model": {"type": "string", "default": "gpt-4o-mini"}
        },
        "required": ["github_username"]
      },
      "steps": [
        {
          "stepId": "list-repos",
          "operationId": "repos/list-for-user",
          "parameters": [
            {"name": "username", "in": "path", "value": "$inputs.github_username"},
            {"name": "sort", "in": "query", "value": "updated"},
            {"name": "per_page", "in": "query", "value": "30"}
          ],
          "successCriteria": [{"condition": "$statusCode == 200"}],
          "outputs": {
            "repos": "$response.body"
          }
        },
        {
          "stepId": "summarise",
          "operationId": "createChatCompletion",
          "requestBody": {
            "contentType": "application/json",
            "payload": {
              "model": "$inputs.openai_model",
              "messages": [
                {
                  "role": "system",
                  "content": "You are a technical analyst summarizing a developer's GitHub profile. Be concise and insightful."
                },
                {
                  "role": "user",
                  "content": "Analyze this developer's GitHub repos and provide: (1) Main technical focus (languages, frameworks), (2) Most notable projects (by stars/forks), (3) Recent activity themes, (4) Overall assessment.\n\nRepos data:\n$steps.list-repos.outputs.repos"
                }
              ]
            }
          },
          "successCriteria": [{"condition": "$statusCode == 200"}],
          "outputs": {
            "summary": "$response.body#/choices/0/message/content"
          }
        }
      ],
      "outputs": {
        "username": "$inputs.github_username",
        "repo_count": "$steps.list-repos.outputs.repos#/length",
        "summary": "$steps.summarise.outputs.summary"
      }
    },
    {
      "workflowId": "analyse-repo-activity",
      "summary": "Fetch recent commits for a repo and analyze activity with OpenAI",
      "description": "Gets the last 30 commits for a specific repo, then uses GPT to identify development patterns, key contributors, and project health.",
      "inputs": {
        "type": "object",
        "properties": {
          "owner": {"type": "string"},
          "repo": {"type": "string"},
          "openai_model": {"type": "string", "default": "gpt-4o-mini"}
        },
        "required": ["owner", "repo"]
      },
      "steps": [
        {
          "stepId": "list-commits",
          "operationId": "repos/list-commits",
          "parameters": [
            {"name": "owner", "in": "path", "value": "$inputs.owner"},
            {"name": "repo", "in": "path", "value": "$inputs.repo"},
            {"name": "per_page", "in": "query", "value": "30"}
          ],
          "successCriteria": [{"condition": "$statusCode == 200"}],
          "outputs": {
            "commits": "$response.body"
          }
        },
        {
          "stepId": "analyse",
          "operationId": "createChatCompletion",
          "requestBody": {
            "contentType": "application/json",
            "payload": {
              "model": "$inputs.openai_model",
              "messages": [
                {
                  "role": "system",
                  "content": "You are analyzing git commit history to assess project health and development patterns."
                },
                {
                  "role": "user",
                  "content": "Analyze these recent commits and provide: (1) Development velocity (commit frequency), (2) Key contributors, (3) Types of changes (features/fixes/docs), (4) Project health assessment.\n\nCommits:\n$steps.list-commits.outputs.commits"
                }
              ]
            }
          },
          "successCriteria": [{"condition": "$statusCode == 200"}],
          "outputs": {
            "analysis": "$response.body#/choices/0/message/content"
          }
        }
      ],
      "outputs": {
        "repo": "$inputs.owner/$inputs.repo",
        "commit_count": "$steps.list-commits.outputs.commits#/length",
        "analysis": "$steps.analyse.outputs.analysis"
      }
    }
  ]
}
