{
  "openapi": "3.0.0",
  "info": {
    "title": "Jentic API",
    "version": "1.0.0",
    "description": "Jentic agent execution layer — search operations and execute workflows"
  },
  "servers": [
    {
      "url": "https://api-gw.main.us-east-1.jenticprod.net/api/v1"
    }
  ],
  "security": [
    {
      "JenticApiKey": []
    }
  ],
  "components": {
    "securitySchemes": {
      "JenticApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-JENTIC-API-KEY"
      }
    }
  },
  "paths": {
    "/agents/search": {
      "post": {
        "operationId": "searchOperations",
        "summary": "Search for API operations by intent",
        "tags": [
          "search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "limit": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results"
          }
        }
      }
    },
    "/agents/execute": {
      "post": {
        "operationId": "executeOperation",
        "summary": "Execute an API operation",
        "tags": [
          "execute"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Execution result"
          }
        }
      }
    },
    "/agents/apis": {
      "get": {
        "operationId": "listApis",
        "summary": "List registered APIs",
        "tags": [
          "catalog"
        ],
        "responses": {
          "200": {
            "description": "API list"
          }
        }
      }
    },
    "/files": {
      "get": {
        "operationId": "getOperationFiles",
        "summary": "Get arazzo workflow files for operations",
        "tags": [
          "catalog"
        ],
        "parameters": [
          {
            "name": "operation_uuids",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File content"
          }
        }
      }
    }
  }
}