{
  "arazzo": "1.0.0",
  "info": {
    "title": "Techpreneurs Forum + OpenAI Workflows",
    "version": "0.1.0",
    "description": "Workflows combining Techpreneurs.ie Discourse forum (read-only) with OpenAI for analysis"
  },
  "sourceDescriptions": [
    {
      "name": "discourse",
      "type": "openapi",
      "url": "/app/src/specs/discourse.patched.json"
    },
    {
      "name": "openai",
      "type": "openapi",
      "url": "/app/src/specs/openai.json"
    }
  ],
  "workflows": [
    {
      "workflowId": "summarise-latest-topics",
      "summary": "Fetch latest Techpreneurs forum topics and summarise with OpenAI",
      "description": "Read-only workflow: fetches the latest topics from Techpreneurs.ie Discourse forum, then uses GPT-4o-mini to produce a concise summary of what the community is discussing.",
      "inputs": {
        "type": "object",
        "properties": {
          "openai_model": {
            "type": "string",
            "default": "gpt-4o-mini",
            "description": "OpenAI model to use for summarisation"
          }
        }
      },
      "steps": [
        {
          "stepId": "fetch-topics",
          "operationId": "listLatestTopics",
          "successCriteria": [
            {
              "condition": "$statusCode == 200"
            }
          ],
          "outputs": {
            "topics": "$response.body#/topic_list/topics"
          }
        },
        {
          "stepId": "summarise",
          "operationId": "createChatCompletion",
          "requestBody": {
            "contentType": "application/json",
            "payload": {
              "model": "$inputs.openai_model",
              "messages": [
                {
                  "role": "system",
                  "content": "You are a helpful assistant summarising discussions from a Dublin tech founders community forum called Techpreneurs. Be concise, insightful, and relevant to a founder audience."
                },
                {
                  "role": "user",
                  "content": "Here are the latest topics from the Techpreneurs forum. Please provide a brief summary (3-5 sentences) of what the community is currently discussing, highlighting any recurring themes or particularly notable conversations.\n\nTopics:\n$steps.fetch-topics.outputs.topics"
                }
              ]
            }
          },
          "successCriteria": [
            {
              "condition": "$statusCode == 200"
            }
          ],
          "outputs": {
            "summary": "$response.body#/choices/0/message/content",
            "model_used": "$response.body#/model"
          }
        }
      ],
      "outputs": {
        "topics": "$steps.fetch-topics.outputs.topics",
        "summary": "$steps.summarise.outputs.summary",
        "model_used": "$steps.summarise.outputs.model_used"
      }
    },
    {
      "workflowId": "analyse-topic",
      "summary": "Fetch a specific Discourse topic and analyse it with OpenAI",
      "description": "Read-only: fetches a specific forum topic with all its posts, then uses OpenAI to extract key insights, action items, and themes from the discussion.",
      "inputs": {
        "type": "object",
        "properties": {
          "api_key": {
            "type": "string",
            "description": "Discourse Api-Key"
          },
          "api_username": {
            "type": "string",
            "description": "Discourse Api-Username"
          },
          "topic_id": {
            "type": "integer",
            "description": "Discourse topic ID"
          },
          "openai_model": {
            "type": "string",
            "default": "gpt-4o-mini"
          }
        },
        "required": [
          "api_key",
          "api_username",
          "topic_id"
        ]
      },
      "steps": [
        {
          "stepId": "fetch-topic",
          "operationId": "getTopic",
          "parameters": [
            {
              "name": "Api-Key",
              "in": "header",
              "value": "$inputs.api_key"
            },
            {
              "name": "Api-Username",
              "in": "header",
              "value": "$inputs.api_username"
            },
            {
              "name": "id",
              "in": "path",
              "value": "$inputs.topic_id"
            }
          ],
          "successCriteria": [
            {
              "condition": "$statusCode == 200"
            }
          ],
          "outputs": {
            "title": "$response.body#/title",
            "posts_count": "$response.body#/posts_count",
            "post_stream": "$response.body#/post_stream"
          }
        },
        {
          "stepId": "analyse",
          "operationId": "createChatCompletion",
          "requestBody": {
            "contentType": "application/json",
            "payload": {
              "model": "$inputs.openai_model",
              "messages": [
                {
                  "role": "system",
                  "content": "You are an AI assistant helping Dublin tech founders extract insights from their community forum discussions. Be concise and practical."
                },
                {
                  "role": "user",
                  "content": "Please analyse this Techpreneurs forum discussion and provide: (1) Main themes discussed, (2) Key insights or advice shared, (3) Any action items or resources mentioned, (4) Overall sentiment.\n\nTopic: $steps.fetch-topic.outputs.title\nPost count: $steps.fetch-topic.outputs.posts_count\n\nThread: $steps.fetch-topic.outputs.post_stream"
                }
              ]
            }
          },
          "successCriteria": [
            {
              "condition": "$statusCode == 200"
            }
          ],
          "outputs": {
            "analysis": "$response.body#/choices/0/message/content"
          }
        }
      ],
      "outputs": {
        "title": "$steps.fetch-topic.outputs.title",
        "analysis": "$steps.analyse.outputs.analysis"
      }
    }
  ]
}