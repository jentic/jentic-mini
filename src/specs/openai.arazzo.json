{
  "arazzo": "1.0.0",
  "info": {"title": "OpenAI Arazzo", "version": "0.1.0"},
  "sourceDescriptions": [
    {"name": "openai", "type": "openapi", "url": "/app/src/specs/openai.json"}
  ],
  "workflows": [
    {
      "workflowId": "chat-completion",
      "summary": "Create a chat completion",
      "inputs": {
        "type": "object",
        "properties": {
          "model": {"type": "string", "default": "gpt-4o-mini"},
          "user_message": {"type": "string"}
        },
        "required": ["user_message"]
      },
      "steps": [
        {
          "stepId": "complete",
          "operationId": "$sourceDescriptions.openai#createChatCompletion",
          "requestBody": {
            "contentType": "application/json",
            "payload": {
              "model": "$inputs.model",
              "messages": [{"role": "user", "content": "$inputs.user_message"}]
            }
          },
          "outputs": {
            "response": "$response.body"
          }
        }
      ],
      "outputs": {
        "completion": "$steps.complete.outputs.response"
      }
    }
  ]
}
