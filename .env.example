# Per-surface database credentials for Docker Compose services.
# Copy this file to .env and adjust as needed.
# Values must match docker/local-setup/init-schemas.sql.

REGISTRY_DB_USER=registry_user
REGISTRY_DB_PASSWORD=registry_pass

CONTROL_DB_USER=control_user
CONTROL_DB_PASSWORD=control_pass

ADMIN_DB_USER=admin_user
ADMIN_DB_PASSWORD=admin_pass
