# Jentic Mini — environment config
# Copy to .env and fill in values before running docker compose

# Host base path — src/ and data/ subdirs are mounted from here.
# Defaults to current directory (.). Only set if running from a different location.
# JENTIC_HOST_PATH=.

# Fernet encryption key for credential vault
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# JENTIC_VAULT_KEY=  # Optional: pin vault key explicitly. Auto-generated from vault.key file if not set.

# Public hostname (used in self-links and arazzo callbacks)
# JENTIC_PUBLIC_HOSTNAME=mini.jentic.com

# Optional path prefix when Mini is mounted under a reverse proxy
# (e.g. example.com/jentic). Empty / unset / "/" all mean "no mount".
# Opt-in: when set, the SPA bundle, hand-rolled /docs and /redoc, and
# self-links resolve under the prefix. When unset, Mini falls back to the
# per-request X-Forwarded-Prefix header (Traefik / nginx Ingress style).
# Pair with JENTIC_PUBLIC_BASE_URL when mounting — that env var must include
# the prefix (e.g. https://example.com/jentic) so OAuth issuer / token aud
# values are correct.
# JENTIC_ROOT_PATH=/jentic

# Log level: debug | info | warning | error
LOG_LEVEL=info

# Optional: trusted subnets for /default-api-key/generate (first-call subnet restric/tion)
# Comma-separated CIDR list. Defaults to RFC 1918 + loopback if not set.
# Extra subnets to trust, in addition to the built-in RFC-1918 + loopback defaults.
# The defaults (10/8, 172.16/12, 192.168/16, 127/8, ::1) always apply — this is purely additive.
# Common additions:
#   100.64.0.0/10   — Tailscale CGNAT range
#   192.0.2.0/24    — your office/VPN egress
# JENTIC_TRUSTED_SUBNETS=100.64.0.0/10

# Telemetry: set to "off" to skip anonymous install registration
# JENTIC_TELEMETRY=off

# ----------------------------------------------------------------------------
# Agent identity (OAuth Dynamic Client Registration)
# ----------------------------------------------------------------------------
# All optional. Sensible defaults are baked into src/config.py — only override
# when you have a deployment-specific reason. Values are seconds unless noted.

# Pin the canonical base URL used to derive the OAuth issuer, the token
# endpoint audience, and persisted registration_client_uri values. When unset,
# these URLs are derived from the inbound Host: / X-Forwarded-Host: header,
# which is fine for a strictly trusted proxy chain but lets a spoofed Host
# rewrite security-sensitive identifiers. Set this to your public origin
# (scheme + host [+ port]) for any internet-facing or shared-tenant deployment.
#   Example: JENTIC_PUBLIC_BASE_URL=https://jentic.example.com
# JENTIC_PUBLIC_BASE_URL=

# Lifetime of a minted at_… access token. Short by design — agents refresh.
# AGENT_ACCESS_TTL=3600           # 1 hour

# Lifetime of a minted rt_… refresh token before mandatory re-registration.
# AGENT_REFRESH_TTL=604800        # 7 days

# Lifetime of the rat_… registration access token returned by POST /register.
# Long enough for an offline human to approve, short enough to bound exposure.
# AGENT_REGISTRATION_TOKEN_TTL=900      # 15 minutes

# Maximum age of a JWT-bearer assertion (RFC 7523) presented at /oauth/token.
# Tighter than the nonce window below — see AGENT_NONCE_WINDOW.
# AGENT_ASSERTION_MAX_AGE=300     # 5 minutes

# How long a successfully-spent jti is remembered to block replay. MUST be
# strictly greater than AGENT_ASSERTION_MAX_AGE — startup will assert this.
# AGENT_NONCE_WINDOW=600          # 10 minutes
